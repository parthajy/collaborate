# collaborate.so — server configuration.
# Copy to `.env` and adjust. Every value is optional; the defaults shown here
# are what the server falls back to. In production these are passed via
# docker-compose `environment:` (or the systemd unit), not a committed file.

# Port the Node process listens on. Nginx proxies to this.
PORT=3000

# Bind address. 127.0.0.1 keeps the process private behind Nginx.
# Use 0.0.0.0 only if you intend to expose it directly.
HOST=127.0.0.1

# "production" or "development". In development the Node process also serves
# the static files in public/; in production Nginx does that instead.
NODE_ENV=production

# Trust the X-Forwarded-For header for per-IP rate limiting.
# Enable ONLY when behind a trusted proxy (Nginx + Cloudflare — which we are).
# If false, the raw socket address is used.
TRUST_PROXY=true
